<?php
namespace Iem\Controller;

use Iem\Ambientes\Ambiente1;
use Iem\Ambientes\Ambiente1Repository;
use \DateTimeImmutable;

class Ambiente1Controller extends Controller{
	private Ambiente1Repository $ambiente1Repository;

	public function __construct(){
		parent::__construct();
		$this->ambiente1Repository = new Ambiente1Repository();
	}

	//funcion para agregar los datos desde el json
	public function registrarDatos(): void{
		header('Content-Type: application/json');

		//leyendo los datos json recibidos
		$json1 = file_get_contents("php://input");
		$datos1 = json_decode($json1, true);

		$temp1 = $datos1['temp_amb1'] ?? null;
		$hum1 = $datos1['hum_amb1'] ?? null;

		if ($temp1 == null || $hum1 == null){
			http_response_code(400);
			echo json_encode(['error' => 'datos incompletos']);
			return;
		}

		//generando la fecha actual
		$fecha1 = new DateTimeImmutable('now');
		
		//guardando datos en la base de datos
		$ambiente1 = new Ambiente1();
		$ambiente1->setTemp($temp1);
		$ambiente1->setHum($hum1);
		$ambiente1->setFecha($fecha1);

		$nuevoDato1 = $this->ambiente1Repository->insert($ambiente1);

		print var_dump($nuevoDato1);
	}	

}


?>
