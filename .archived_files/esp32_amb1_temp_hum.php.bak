<?php
//PROGRAMA PARA RECIBIR LOS DATOS DE TEMPERATURA Y HUMEDAD DESDE EL ESP32 DEL AMBIENTE 1

//configurando la recepcion de datos mediante JSON
header('Content-Type: application/json; charset=utf-8');

//direccion del archivo en el que se va a guardar los datos
$archivo_th_amb1 = 'json_files/esp32_amb1_th.json';

//validando la solicitud del esp32_amb1 tipo POST
if (!isset($_SERVER['REQUEST_METHOD']) || $_SERVER['REQUEST_METHOD'] !== 'POST'){
	//error de metodo no permitido
	http_response_code(405);
	echo json_encode(['error' => 'Metodo no permitido']);
	//saliendo del programa 
	exit;
}

//si el metodo es el correcto, leer y decodificar los datos JSON recibidos
$datos_puros = file_get_contents("php://input");
$datos_decode = json_decode($datos_puros, true);

//verificando si existen datos en los datos_decodificados
if (!$datos_decode){
	//error de bad request
	http_response_code(400);
	echo json_encode(['error' => 'JSON de datos no valido']);
	//saliendo del programa
	exit;
}

//si existen los datos JSON, se procede a validar
$temp_amb1 = isset($datos_decode['temp_amb1']) 
	? floatval($datos_decode['temp_amb1']) : null;
$hum_amb1 = isset($datos_decode['hum_amb1']) 
	? floatval($datos_decode['hum_amb1']) : null;

//verificando que hayan parametros en las variables temp_amb1 y hum_amb1
if (empty($temp_amb1) || empty($hum_amb1)){
	//error de bad request
	http_response_code(400);
	echo json_encode(['error' => 'JSON incompleto. Faltan parametros']);
	//saliendo del programa
	exit;
}

//***********HACER LA AUTENTIFICACION DEL DISPOSITIVO AQUI***********

//creando los datos a guardar en el archivo JSON
$datos_actuales_th = [
	'temperatura_amb1' => $temp_amb1,
	'humedad_amb1' => $hum_amb1,
	'tiempo_registro' => date('Y-m-d H:i:s')
];

//guardando el archivo JSON
$escribiendo_archivo_th = file_put_contents($archivo_th_amb1, json_encode($datos_actuales_th, JSON_PRETTY_PRINT));

//verificacion del archivo guardado exitosamente
$archivo_th_creado = ($escribiendo_archivo_th !== false);

//respuesta al dispositivo
$respuesta = [
	'mensaje' => 'Datos TH recibidos',
	'registro_servidor_th' => $archivo_th_creado ? 'Registrado en SERVIDOR TH' : 'Error de registro TH'
];

echo json_encode($respuesta);


?>
