{% extends 'base.html.twig' %}

{% block title %}Agregar Dispositivo{% endblock %}
{% block dispositivosLink %}active{% endblock %}

{% block body %}
<div class="container mt-5">
	<div class="d-flex align-items-center py-4">
		<main class="w-100 m-auto mt-5" style="max-width: 350px">
			<h1 class="h2 text-center mb-4 fw-normal">Agregar Dispositivo</h1>

			<form method="POST" action="/umsa-iem/public/?action=procesoRegistrarDisp">
				<div class="form-floating mb-3">
					<input type="text" class="form-control" id="floatingInput" name="identificador" placeholder="Identificador">
					<label for="floatingInput">Identificador</label>
				</div>

				<div class="form-floating mb-3">
					<input type="text" class="form-control" id="floatingInput" name="nombre_disp" placeholder="Nombre">
					<label for="floatingInput">Nombre de Dispositivo/Ambiente</label>
				</div>

				<button type="submit" class="btn btn-primary mt-4 mb-5 w-100">Registrar</button>
			</form>
		</main>
	</div>

</div>



{% endblock %}
