{% extends 'base.html.twig' %}

{% block title %}Dispositivos{% endblock %}
{% block reportesLink %}active{% endblock %}

{% block body %}
<div class="container mt-5">
	<h2 class="text-center">Gestión de Dispositivos</h2>

	<table class="table table-striped table-hover mt-3 table-sm" style="vertical-align: middle;">
		<thead>
			<tr>
				<th scope="col">#</th>
				<th scope="col">Identificador</th>
				<th scope="col">Dispositivo/Ambiente</th>
				<th scope="col">Estado</th>
				<th scope="col">Última Conexión</th>
			</tr>
		</thead>
		<tbody>
			{% for dispositivo in dispositivos %}
			<tr>
				<th scope="row">{{ dispositivo.id }}</th>
				<td>{{ dispositivo.identificador }}</td>
				<td>{{ dispositivo.nombreDisp }}</td>
				{% if dispositivo.estado == 1 %}
				<td><span class="badge rounded-pill text-bg-success">Conectado</span></td>
				{% elseif dispositivo.estado == 0 %}
				<td><span class="badge rounded-pill text-bg-danger">Desconectado</span></td>
				{% endif %}

				<td>{{ dispositivo.ultimaConexion|date('Y-m-d H:i:s') }}</td>
			</tr>
			{% endfor %}
		</tbody>
	</table>

</div>
{% endblock %}
