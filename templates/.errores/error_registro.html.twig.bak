{% extends 'base.html.twig' %}

{% block title %}Registrar Usuario{% endblock %}
{% block usuariosLink %}active{% endblock %}

{% block body %}
<div class="container mt-2">
	<div class="d-flex align-items-center py-4 bg-body-tertiary" style="">
		<main class="w-100 m-auto mt-5" style="max-width: 350px">
			<h1 class="h2 text-center mb-4 fw-normal">Registrar Usuario</h1>

			<form method="POST" action="/umsa-iem/public/?action=procesoRegistrar">
				<div>
					<p class="alert alert-danger">{{ mensaje }}</p>
				</div>

				<div class="form-floating mb-3">
					<input type="text" class="form-control" id="floatingInput" name="nombre" placeholder="Nombre">
					<label for="floatingInput">Nombre</label>
				</div>

				<div class="form-floating mb-3">
					<input type="text" class="form-control" id="floatingInput" name="apellido" placeholder="Apellido">
					<label for="floatingInput">Apellido</label>
				</div>

				<div class="form-floating mb-3">
					<input type="text" class="form-control" id="floatingInput" name="username" placeholder="usuario">
					<label for="floatingInput">Nombre de Usuario</label>
				</div>

				<div class="form-floating">
					<input type="password" class="form-control" id="floatingPassword" name="password" placeholder="Contraseña">
					<label for="floatingPassword">Contraseña</label>
				</div>

				<button type="submit" class="btn btn-warning mt-4 mb-5 w-100">Registrar</button>
			</form>
		</main>
	</div>

</div>



{% endblock %}
