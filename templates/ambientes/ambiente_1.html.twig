<script>
//*************************************************************
// This is an example script, please modify as needed
const rangoIn = document.getElementById('vel_vent');
const rangoPorcentaje = document.getElementById('vel_vent_out');
const rangoCaudal = document.getElementById('caudal_vent');

//funcion para actualizar los valores del porcentaje y caudal
function valoresVent(valor){
	let valor_caudal = (valor * (16 / 100)).toFixed(2);

	//pasando los valores
	rangoPorcentaje.textContent = valor;
	rangoCaudal.textContent = valor_caudal;

	//console.log(valor);
	//console.log(valor_caudal);
}

//escuchando el evento del deslizador
rangoIn.addEventListener('input', function() {
	valoresVent(this.value);
});

//ejecutar al inciar la pagina
valoresVent(rangoIn.value);

//*************************************************************
const DEVICE_ID = 'esp_amb1';

//conectando al websocket
//const wsServer = 'ws://10.245.59.12:8080';
const wsServer = 'ws://192.168.1.8:8080';
let websocket = null;
let intervalo_reconex = 5000; //intentando reconectar cada 5s
let contador_reconex = 0;
let intervaloHeartbeat = null;

//****************************************
//RECOPILANDO ELEMENTOS DEL DOCUMENTO HTML
//para el estado del ventilador
const estadoVent = document.getElementById('estadoVent');
const valorTemp1 = document.getElementById('temp1-vivo');
const valorHum1 = document.getElementById('hum1-vivo');
const valorFecha1 = document.getElementById('fecha1-vivo');
const estadoMonitor1 = document.getElementById('ws-status');

//****************************************


//CONEXION CON EL SERVIDOR WEBSOCKET
function conectarWS(){
	if (contador_reconex <= 50){
		websocket = new WebSocket(wsServer);
		//ABRIR
		websocket.onopen = function (event) {
			console.log("Connected to WebSocket server.");
			contador_reconex = 0;

			//para el indicador de parpadeo
			estadoMonitor1.classList.remove('bg-warning', 'bg-danger');
			
			 //limpiando heartbeat si lo hubiera
			if (intervaloHeartbeat){
				clearInterval(intervaloHeartbeat);
				intervaloHeartbeat = null;
			}

			//intervalo de para enviar un heartbeat
			intervaloHeartbeat = setInterval(() => {
				if (websocket.readyState === WebSocket.OPEN) {
					const heartbeat = {
						id_disp: "cliente_web",
						action: "heartbeat",
						estado: "vivo",
					};

					websocket.send(JSON.stringify(heartbeat));
					console.log(heartbeat);
				}
			}, 15000);

		};

		//MENSAJE
		websocket.onmessage = function (event){
			try{
				//data son los datos emitidos y estos son guardados en datos_atrapados
				const datos_atrapados = JSON.parse(event.data);

				if (datos_atrapados.action === 'datos_actualizados' && datos_atrapados.id_disp === DEVICE_ID){
					valorTemp1.innerText = parseFloat(datos_atrapados.temp).toFixed(1);
					valorHum1.innerText = parseFloat(datos_atrapados.hum).toFixed(1);
					valorFecha1.innerText = datos_atrapados.fecha;
						
					//Efecto visual: parpadeo suave en el log para saber que está vivo
					estadoMonitor1.classList.add('bg-warning');
					setTimeout(() => {
						estadoMonitor1.classList.remove('bg-warning');
						estadoMonitor1.classList.add('bg-success');
						//estadoMonitor1.innerText = "Conectado";
					}, 150);
				}		

				else if (datos_atrapados.action === 'feedbackVent' && datos_atrapados.id_disp === DEVICE_ID){
					if (datos_atrapados.estado_ahora == 1){
						estadoVent.innerText = 'Activado';
						estadoVent.classList.remove('bg-danger', 'bg-orange', 'bg-warning');
						estadoVent.classList.add('bg-success');
					}
					else if (datos_atrapados.estado_ahora == 0){
						estadoVent.innerText = 'Desactivado';
						estadoVent.classList.remove('bg-success', 'bg-orange', 'bg-warning');
						estadoVent.classList.add('bg-danger');
					}
				}
				else if (datos_atrapados.action === 'feedbackCalent' && datos_atrapados.id_disp === DEVICE_ID){
					if (datos_atrapados.estado_ahora == 1){
						estadoCalent.innerText = 'Activado';
						estadoCalent.classList.remove('bg-danger', 'bg-orange', 'bg-warning');
						estadoCalent.classList.add('bg-success');
					}
					else if (datos_atrapados.estado_ahora == 0){
						estadoCalent.innerText = 'Desactivado';
						estadoCalent.classList.remove('bg-success', 'bg-orange', 'bg-warning');
						estadoCalent.classList.add('bg-danger');
					}
				}
				else if (datos_atrapados.action === 'feedbackHumi' && datos_atrapados.id_disp === DEVICE_ID){
					if (datos_atrapados.estado_ahora == 1){
						estadoHumi.innerText = 'Activado';
						estadoHumi.classList.remove('bg-danger', 'bg-orange', 'bg-warning');
						estadoHumi.classList.add('bg-success');
					}
					else if (datos_atrapados.estado_ahora == 0){
						estadoHumi.innerText = 'Desactivado';
						estadoHumi.classList.remove('bg-success', 'bg-orange', 'bg-warning');
						estadoHumi.classList.add('bg-danger');
					}
				}
			} catch(error){
				console.error("Error al atrapar los datos", error);	
			}

		}

		//CERRAR
		websocket.onclose = function (event) {
			//limpiando heartbeat para la desconexion
			if (intervaloHeartbeat){
				clearInterval(intervaloHeartbeat);
				intervaloHeartbeat = null;
			}

			console.log("Disconnected");
			estadoMonitor1.classList.remove('bg-danger', 'bg-success');
			estadoMonitor1.classList.add('bg-danger');
			
			//para el span del ventilador
			estadoVent.innerText = 'Sin Datos';
			estadoVent.classList.remove('bg-success', 'bg-warning', 'bg-danger');
			estadoVent.classList.add('bg-orange');
			
			//para el span del calentador
			estadoCalent.innerText = 'Sin Datos';
			estadoCalent.classList.remove('bg-success', 'bg-warning', 'bg-danger');
			estadoCalent.classList.add('bg-orange');

			//para el span del humidificador
			estadoHumi.innerText = 'Sin Datos';
			estadoHumi.classList.remove('bg-success', 'bg-warning', 'bg-danger');
			estadoHumi.classList.add('bg-orange');

			//intentanto reconectar
			setTimeout(function(){
				conectarWS();	
			}, intervalo_reconex);
		};

		//ERROR
		websocket.onerror = function (event, e) {
			console.log('Error occurred: ' + event.data);
		};

	}
	else {
		console.log("Los intentos de reconexion han llegado a su limite");
	}
	contador_reconex++;
}

//*************************************************************
//conectando el servidor WebSocket
conectarWS();
//*************************************************************

//funcion para enviar mensajes hacia el servidor WebSocket
function enviarOrdenVent(estado){
	const payload = {
		id_objetivo: DEVICE_ID,
		action: "comando",
		tipo: "ordenVent",
		valor: estado,		
	}

	//verficando que el servidor este abierto: true
	if (websocket.readyState === WebSocket.OPEN){
		const mensaje = JSON.stringify(payload);
		websocket.send(mensaje);
		console.log("Datos enviados: ", mensaje);

		//cambiando el estado del span 
		if (estado == 1){
			estadoVent.innerText = 'Activando';
			estadoVent.classList.remove('bg-danger', 'bg-orange', 'bg-success');
			estadoVent.classList.add('bg-warning');
		}
		else if (estado == 0){
			estadoVent.innerText = 'Desactivando';
			estadoVent.classList.remove('bg-success', 'bg-orange', 'bg-danger');
			estadoVent.classList.add('bg-warning');
		}
	}
	else{
		console.log("El servidor no esta conectado");
	}
}

//orden para el calentador
function enviarOrdenCalent(estado){
	const payload = {
		id_objetivo: DEVICE_ID,
		action: "comando",
		tipo: "ordenCalent",
		valor: estado,		
	}

	//verficando que el servidor este abierto: true
	if (websocket.readyState === WebSocket.OPEN){
		const mensaje = JSON.stringify(payload);
		websocket.send(mensaje);
		console.log("Datos enviados: ", mensaje);

		//cambiando el estado del span 
		if (estado == 1){
			estadoCalent.innerText = 'Activando';
			estadoCalent.classList.remove('bg-danger', 'bg-orange', 'bg-success');
			estadoCalent.classList.add('bg-warning');
		}
		else if (estado == 0){
			estadoCalent.innerText = 'Desactivando';
			estadoCalent.classList.remove('bg-success', 'bg-orange', 'bg-danger');
			estadoCalent.classList.add('bg-warning');
		}
	}
	else{
		console.log("El servidor no esta conectado");
	}
}

//orden para el humidificador
function enviarOrdenHumi(estado){
	const payload = {
		id_objetivo: DEVICE_ID,
		action: "comando",
		tipo: "ordenHumi",
		valor: estado,		
	}

	//verficando que el servidor este abierto: true
	if (websocket.readyState === WebSocket.OPEN){
		const mensaje = JSON.stringify(payload);
		websocket.send(mensaje);
		console.log("Datos enviados: ", mensaje);

		//cambiando el estado del span 
		if (estado == 1){
			estadoHumi.innerText = 'Activando';
			estadoHumi.classList.remove('bg-danger', 'bg-orange', 'bg-success');
			estadoHumi.classList.add('bg-warning');
		}
		else if (estado == 0){
			estadoHumi.innerText = 'Desactivando';
			estadoHumi.classList.remove('bg-success', 'bg-orange', 'bg-danger');
			estadoHumi.classList.add('bg-warning');
		}
	}
	else{
		console.log("El servidor no esta conectado");
	}
}
//***************************************************************************
//RECUPERAR ULTIMOS VALORES DE TEMPERATURA Y HUMEDAD DE LA DB
//function para obtener el ultimo dato desde la base de datos
async function cargarUltimosDatos() {
	//se buscan los ultimos datos de temperatura, humedad y fecha
	try{
		const response = await fetch(`?action=consulta_datos&id_disp=${DEVICE_ID}`);
		const datos = await response.json();

		if (datos.estado === 'datos_recuperados'){
			console.log("Datos cargados desde la BD: ", datos);
			//actualizando los datos en la interfaz
			document.getElementById('temp1-vivo').innerText = parseFloat(datos.temp).toFixed(1);
			document.getElementById('hum1-vivo').innerText = parseFloat(datos.hum).toFixed(1);
			document.getElementById('fecha1-vivo').innerText = datos.fecha;
		}
	}
	catch (error){
		console.error("Error al recuperar los datos: ", error);
	}
}

document.addEventListener("DOMContentLoaded", function() {
	cargarUltimosDatos();
});

